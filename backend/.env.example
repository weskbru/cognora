# ── Banco de dados ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Em produção (Railway): cole a URL gerada automaticamente pela plataforma
DATABASE_URL=postgresql://cognora:cognora@localhost:5432/cognora

# ── Segurança JWT ─────────────────────────────────────────────────────────────
# Gere um valor seguro com: python -c "import secrets; print(secrets.token_hex(32))"
# NUNCA use o valor padrão abaixo em produção
SECRET_KEY=troque-por-uma-chave-segura-gerada-aleatoriamente

# ── API de IA (OpenRouter) ────────────────────────────────────────────────────
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-SUBSTITUA_PELA_SUA_CHAVE

# ── CORS ─────────────────────────────────────────────────────────────────────
# Em desenvolvimento: deixe em branco ou use * (qualquer origem)
# Em produção: liste as origens permitidas separadas por vírgula
# Exemplo: ALLOWED_ORIGINS=https://cognora.vercel.app,https://www.cognora.com.br
ALLOWED_ORIGINS=*
