{
  "name": "Subject",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da mat\u00e9ria"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da mat\u00e9ria"
    },
    "color": {
      "type": "string",
      "description": "Cor da mat\u00e9ria para identifica\u00e7\u00e3o visual"
    },
    "icon": {
      "type": "string",
      "description": "\u00cdcone da mat\u00e9ria"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}